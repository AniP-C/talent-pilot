{
  "manifest_version": 3,
  "name": "AI Job Copilot",
  "version": "1.0",
  "description": "Passive AI assistant for job applications",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["rules.js", "content.js"]
    }
  ]
}